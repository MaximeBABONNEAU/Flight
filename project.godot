; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="MERLIN"
; v7.7.15 — main_scene moved from IntroCeltOS to MenuTest per user decision
; "le CeltOS ne doit pas être présenté de cette manière du coup".
; IntroCeltOS.tscn stays in repo (callable via SceneSelector debug if needed).
run/main_scene="res://scenes/MenuTest.tscn"
run/max_fps=60
config/features=PackedStringArray("4.5", "GL Compatibility")
boot_splash/bg_color=Color(0.02, 0.04, 0.02, 1)
boot_splash/show_image=false
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/game_manager.gd"
MerlinAI="*res://addons/merlin_ai/merlin_ai.gd"
MerlinStats="*res://scripts/merlin/merlin_stats_system.gd"
MerlinBackdrop="*res://scripts/merlin_backdrop.gd"
ScreenFrame="*res://scripts/autoload/screen_frame.gd"
ScreenEffects="*res://scripts/autoload/ScreenEffects.gd"
SceneSelector="*res://scripts/autoload/SceneSelector.gd"
LocaleManager="*res://scripts/autoload/LocaleManager.gd"
I18nRegistry="*res://scripts/autoload/i18n_registry.gd"
SFXManager="*res://scripts/autoload/SFXManager.gd"
MerlinVisual="*res://scripts/autoload/merlin_visual.gd"
PixelTransition="*res://scripts/autoload/pixel_transition.gd"
PixelContentAnimator="*res://scripts/autoload/pixel_content_animator.gd"
WorldMapSystem="*res://scripts/autoload/world_map_system.gd"
MusicManager="*res://scripts/autoload/music_manager.gd"
GameTimeManager="*res://scripts/autoload/game_time_manager.gd"
InputAdapter="*res://scripts/autoload/input_adapter.gd"
PlatformManager="*res://scripts/autoload/platform_manager.gd"
ScreenDither="*res://scripts/ui/screen_dither_layer.gd"
GameDebugServer="*res://scripts/test/game_debug_server.gd"
CaptureRecorder="*res://scripts/autoload/capture_recorder.gd"
PerfRecorder="*res://scripts/autoload/perf_recorder.gd"
MerlinMetrics="*res://scripts/autoload/merlin_metrics.gd"
DayNightManager="*res://scripts/autoload/day_night_manager.gd"
MerlinResponsive="*res://scripts/autoload/merlin_responsive.gd"
GameFlow="*res://scripts/core/game_flow_controller.gd"
FPSOverlay="*res://scripts/autoload/fps_overlay.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/window_width_override=1920
window/size/window_height_override=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=5
; v7.7.15 — Force VSync ON (no tearing). 1 = enabled (default in Godot 4 but explicit).
window/vsync/vsync_mode=1

[editor_plugins]

enabled=PackedStringArray("res://addons/error_clipboard_dock/plugin.cfg", "res://addons/gd_script_deployer/plugin.cfg", "res://addons/godot_mcp/plugin.cfg")

[gui]

theme/custom="res://themes/merlin_theme.tres"

[internationalization]

locale/translations=PackedStringArray("res://data/i18n/translations.fr.translation", "res://data/i18n/translations.en.translation", "res://data/i18n/translations.es.translation", "res://data/i18n/translations.it.translation", "res://data/i18n/translations.pt.translation", "res://data/i18n/translations.zh.translation", "res://data/i18n/translations.ja.translation")
locale/fallback="fr"

[merlin_llm]

log_enabled=true
log_verbose=true
log_path="user://merlin_llm/merlin.log"
allow_native_in_editor=true
require_native=true
low_spec_mode=true

[physics]

3d/physics_engine="JoltPhysics3D"

[rendering]

renderer/rendering_method.mobile="gl_compatibility"
; v7.7.16 — Aggressive 60 FPS audit per user request « 60 fps constants ».
; MSAA 2→0 + FXAA on (lighter on GL Compatibility renderer).
; scaling_3d/scale=0.90 = render at 90% then upscale (15-20% GPU saving).
; mesh_lod threshold 1.0→4.0 = aggressive LOD on distant meshes.
anti_aliasing/quality/msaa_3d=0
; v7.7.18 — FXAA DISABLED. On GL Compatibility renderer FXAA adds 3-5ms/frame
; (Explore agent audit). Major culprit for 60 FPS instability. With scaling_3d=0.9
; the low-poly aesthetic forgives aliasing — re-enable only if visibly jagged.
anti_aliasing/quality/screen_space_aa=0
scaling_3d/scale=0.9
mesh_lod/lod_change/threshold_pixels=4.0
environment/defaults/default_clear_color=Color(0.039, 0.039, 0.071, 1)
